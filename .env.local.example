# ===== База данных (PostgreSQL) =====
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/hr_assistant

# ===== NextAuth =====
NEXTAUTH_SECRET=your_random_secret_here_minimum_32_chars
NEXTAUTH_URL=http://localhost:3000

# ===== AI API (ОБЯЗАТЕЛЬНО — выберите один из вариантов) =====

# --- Вариант 1: DeepSeek (бесплатные кредиты при регистрации) ---
# OPENAI_API_KEY=sk-ваш-ключ-deepseek
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat

# --- Вариант 2: OpenAI (платный, от $5) ---
# OPENAI_API_KEY=sk-ваш-ключ-openai
# OPENAI_MODEL=gpt-4o-mini

# --- Вариант 3: Groq (бесплатный, быстрый) ---
# OPENAI_API_KEY=gsk_ваш-ключ-groq
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
